# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token

# Anthropic (Claude API for caption generation)
ANTHROPIC_API_KEY=your-anthropic-key

# Kie.ai (Nano Banana 2 — image generation)
KIE_AI_API_KEY=your-kie-ai-key

# ElevenLabs (Phase 2 — voiceover)
ELEVENLABS_API_KEY=your-elevenlabs-key

# Postiz (self-hosted, posting engine)
POSTIZ_URL=http://localhost:5000
POSTIZ_API_KEY=your-postiz-key

# Worker config
MAX_WORKER_CONCURRENCY=3
WORKER_POLL_INTERVAL_SECONDS=5
